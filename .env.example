# Copy to .env for `docker compose up`. These are dev-only defaults.

# ── MySQL ──────────────────────────────────────────────
MYSQL_DATABASE=puckhate
MYSQL_USER=puckhate
MYSQL_PASSWORD=puckhate
MYSQL_ROOT_PASSWORD=root

# ── Django backend ─────────────────────────────────────
DJANGO_SECRET_KEY="%46z8e#@*u!=2(w@a1b1o7*0o9h_b%@0y(hht#b@(-q%)zkfac"
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
SITE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
DB_DEFAULT_NAME=puckhate
