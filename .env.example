# Copy to .env for `docker compose up`. These are dev-only defaults.

# ── MySQL ──────────────────────────────────────────────
MYSQL_DATABASE=puckcurl
MYSQL_USER=puckcurl
MYSQL_PASSWORD=puckcurl
MYSQL_ROOT_PASSWORD=root

# ── Django backend ─────────────────────────────────────
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173

DB_DEFAULT_NAME=puckcurl
DB_DEFAULT_USER=puckcurl
DB_DEFAULT_PASSWORD=puckcurl
DB_DEFAULT_HOST=db
DB_DEFAULT_PORT=3306

# ── Frontend (Vite) ────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_PROXY_TARGET=http://backend:8000
